{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "version": "1.0.1",
  "name": "@nodejs-loaders/text",
  "exports": "./text.js",
  "publish": {
    "include": [
      "./*.js",
      "./*.d.ts",
      "./*.d.ts.map"
    ],
    "exclude": [
      "!./*.js",
      "!./*.d.ts",
      "!./*.d.ts.map",
      "./*.bench.js",
      "./*.test.js",
      "./*.spec.js",
      "./fixtures/**/*"
    ]
  }
}
